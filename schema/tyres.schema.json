{
  "$schema": "https://spec.openapis.org/oas/3.1/meta/base",
  "$id": "tyres",
  "title": "Tyres",
  "description": "Tyres for a vehicle",
  "type": "object",
  "properties": {
    "print_name": {
      "description": "Printable name for the tyre",
      "type": "string"
    },
    "effective_radius": {
      "description": "Effective radius of the tyre, in metres",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "mu_x_peak": {
      "description": "Peak longitudinal grip coefficient",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "mu_x_sens": {
      "description": "Longitudinal load sensitivity",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "mu_y_peak": {
      "description": "Peak lateral grip coefficient",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "mu_y_sens": {
      "description": "Lateral load sensitivity",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "slip_stiffness": {
      "description": "Slip stiffness of the tyre",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "cornering_stiffness": {
      "description": "Cornering stiffness of the tyre",
      "type": "number",
      "exclusiveMinimum": 0
    }
  },
  "required": [
    "print_name",
    "effective_radius",
    "mu_x_peak",
    "mu_x_sens",
    "mu_y_peak",
    "mu_y_sens",
    "slip_stiffness",
    "cornering_stiffness"
  ],
  "additionalProperties": false
}
