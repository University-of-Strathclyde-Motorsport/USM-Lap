{
  "$schema": "https://spec.openapis.org/oas/3.1/meta/base",
  "$id": "cells",
  "title": "Cells",
  "description": "Cells for the accumulator",
  "type": "object",
  "properties": {
    "print_name": {
      "description": "Printable name of the cell",
      "type": "string"
    },
    "capacity": {
      "description": "Capacity of the cell, in joules",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "charge_capacity": {
      "description": "Capacity of the cell, in Coulombs",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "thermal_mass": {
      "description": "Thermal mass of the cell, in J / K",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "nominal_voltage": {
      "description": "Nominal voltage of the cell, in volts",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "voltage_lookup": {
      "description": "Lookup table for cell voltage as a function of state of charge",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "state_of_charge": {
            "description": "Reference state of charge",
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "voltage": {
            "description": "Voltage at reference state of charge",
            "type": "number",
            "exclusiveMinimum": 0
          }
        },
        "required": ["state_of_charge", "voltage"],
        "additionalProperties": false
      },
      "minItems": 2
    },
    "resistance_lookup": {
      "description": "Lookup table for cell resistance as a function of temperature",
      "type": "array",
      "items": { "$ref": "#/$defs/resistance_lookup" },
      "minItems": 1
    },
    "max_discharge_current": {
      "description": "Maximum continuous discharge current, in amps",
      "type": "number",
      "exclusiveMinimum": 0
    },
    "datasheet_url": {
      "description": "URL to the datasheet of the cell",
      "type": "string"
    }
  },
  "required": [
    "print_name",
    "capacity",
    "charge_capacity",
    "thermal_mass",
    "nominal_voltage",
    "voltage_lookup",
    "resistance_lookup",
    "max_discharge_current"
  ],
  "additionalProperties": false,

  "$defs": {
    "voltage_lookup": {
      "type": "object",
      "properties": {
        "state_of_charge": {
          "description": "Reference state of charge",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "voltage": {
          "description": "Voltage at reference state of charge",
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "required": ["state_of_charge", "voltage"],
      "additionalProperties": false
    },

    "resistance_lookup": {
      "type": "object",
      "properties": {
        "temperature": {
          "description": "Reference temperature, in degrees Celsius",
          "type": "number",
          "minimum": -273.15
        },
        "lookup": {
          "type": "array",
          "items": { "$ref": "#/$defs/soc_resistance_lookup" },
          "minItems": 2
        }
      },
      "required": ["temperature", "lookup"],
      "additionalProperties": false
    },

    "soc_resistance_lookup": {
      "type": "object",
      "properties": {
        "state_of_charge": {
          "description": "Reference state of charge",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "resistance": {
          "description": "Resistance at reference state of charge",
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "required": ["state_of_charge", "resistance"],
      "additionalProperties": false
    }
  }
}
